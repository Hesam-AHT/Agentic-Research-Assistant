export async function startInteractiveCLI() {
  const readline = require("readline");
  const rl = readline.createInterface({
    input: process.stdin,
    output: process.stdout,
  });

  console.log("\n" + "=".repeat(60));
  console.log("A0 Interactive Research Assistant");
  console.log("=".repeat(60));
  console.log("Commands:");
  console.log("  /help     - Show help");
  console.log("  /memory   - Show memory summary");
  console.log("  /reset    - Reset memory");
  console.log("  /feedback - Provide feedback on last answer");
  console.log("  /quit     - Exit");
  console.log("=".repeat(60) + "\n");

  let lastQuery = "";

  const askQuestion = () => {
    rl.question("\n> ", async (input: string) => {
      const text = input.trim();

      if (!text) {
        askQuestion();
        return;
      }

      // Handle commands
      if (text.startsWith("/")) {
        const cmd = text.toLowerCase();

        if (cmd === "/quit" || cmd === "/exit") {
          console.log("\nGoodbye!");
          rl.close();
          return;
        }

        if (cmd === "/help") {
          console.log("\nAvailable commands:");
          console.log("  /help     - Show this help");
          console.log("  /memory   - Show memory summary");
          console.log("  /reset    - Reset memory");
          console.log("  /feedback - Provide feedback");
          console.log("  /quit     - Exit");
          askQuestion();
          return;
        }

        if (cmd === "/memory") {
          console.log("\nMemory Summary:");
          console.log(memoryManager.getSummary());
          askQuestion();
          return;
        }

        if (cmd === "/reset") {
          resetMemory();
          console.log("\nMemory reset complete.");
          askQuestion();
          return;
        }

        if (cmd === "/feedback") {
          if (!lastQuery) {
            console.log("\nNo previous query to provide feedback on.");
            askQuestion();
            return;
          }

          rl.question("Feedback: ", async (feedback: string) => {
            await provideFeedback(lastQuery, feedback);
            console.log("\nFeedback recorded. Thank you!");
            askQuestion();
          });
          return;
        }

        console.log("\nUnknown command. Type /help for available commands.");
        askQuestion();
        return;
      }

      // Process query
      lastQuery = text;

      const userQuery: UserQuery = {
        text,
        expertise: "intermediate",
        format: "markdown",
      };

      const result = await processQuery(userQuery);

      console.log("\n" + "=".repeat(60));
      console.log("ANSWER:");
      console.log("=".repeat(60));
      console.log(result.answer || result.message || JSON.stringify(result, null, 2));

      if (result.citations && result.citations.length > 0) {
        console.log("\n" + "-".repeat(60));
        console.log("CITATIONS:");
        console.log("-".repeat(60));
        result.citations.forEach((c: any) => {
          console.log(c.formatted || JSON.stringify(c));
        });
      }

      if (result.metadata) {
        console.log("\n" + "-".repeat(60));
        console.log("METADATA:");
        console.log("-".repeat(60));
        console.log(JSON.stringify(result.metadata, null, 2));
      }

      askQuestion();
    });
  };

  askQuestion();
}

