export async function processQuery(
  userQuery: UserQuery
): Promise<any> {
  console.log("\n" + "█".repeat(60));
  console.log("█" + " ".repeat(18) + "A0 CONTROLLER START" + " ".repeat(19) + "█");
  console.log("█".repeat(60));
  console.log(`Query: ${userQuery.text}`);
  console.log(`Sources: ${userQuery.sources?.join(", ") || "none"}`);
  console.log("█".repeat(60) + "\n");

  try {
    // Reset task manager for new query
    taskManager.reset();

    // Run controller
    const result = await runController(userQuery);

    // Store in memory
    if (result.answer) {
      memoryManager.addConversation(userQuery.text, result.answer);
    }

    return result;
  } catch (error) {
    console.error("\n[A0 CRITICAL ERROR]", error);
    return {
      status: "error",
      error: String(error),
    };
  }
}

export async function provideFeedback(
  query: string,
  feedback: string
): Promise<void> {
  memoryManager.addFeedback(query, feedback);
  console.log("\n[A0] Feedback recorded");
}

export function resetMemory(): void {
  memoryManager.reset();
  taskManager.reset();
  console.log("\n[A0] Memory reset");
}

export function getMemory(): Memory {
  return memoryManager.getMemory();
}

