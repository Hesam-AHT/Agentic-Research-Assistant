// ============================================================================
// TASK MANAGER
// ============================================================================

class TaskManager {
  private tasks: Map<string, Task> = new Map();
  private taskCounter = 0;

  createTask(
    type: "ingest" | "retrieve" | "reason",
    agent: "A1" | "A2",
    inputs: any,
    dependencies: string[] = []
  ): string {
    const id = `task_${++this.taskCounter}`;
    this.tasks.set(id, {
      id,
      type,
      agent,
      inputs,
      dependencies,
      status: "pending",
      retries: 0,
      maxRetries: 3,
    });
    return id;
  }

  getTask(id: string): Task | undefined {
    return this.tasks.get(id);
  }

  updateTaskStatus(
    id: string,
    status: Task["status"],
    result?: any
  ) {
    const task = this.tasks.get(id);
    if (task) {
      task.status = status;
      if (result) task.result = result;
    }
  }

  canExecute(taskId: string): boolean {
    const task = this.tasks.get(taskId);
    if (!task || task.status !== "pending") return false;

    return task.dependencies.every((depId) => {
      const dep = this.tasks.get(depId);
      return dep && dep.status === "completed";
    });
  }

  getPendingTasks(): Task[] {
    return Array.from(this.tasks.values()).filter(
      (t) => t.status === "pending"
    );
  }

  getAllTasks(): Task[] {
    return Array.from(this.tasks.values());
  }

  reset() {
    this.tasks.clear();
    this.taskCounter = 0;
  }
}

const taskManager = new TaskManager();

// ============================================================================
// TOOL EXECUTION
// ============================================================================

async function executeFunction(
  name: string,
  args: Record<string, any>
): Promise<any> {
  console.log(`\n[A0 TOOL] ${name}`);

  switch (name) {
    case "decompose_query": {
      const { main_query, sub_queries } = args;
      
      memoryManager.addQuery(main_query);
      
      const subQueryObjects: SubQuery[] = sub_queries.map(
        (sq: any, i: number) => ({
          id: `subq_${i + 1}`,
          text: sq.text,
          priority: sq.priority || i + 1,
          status: "pending" as const,
        })
      );

      return {
        success: true,
        main_query,
        sub_queries: subQueryObjects,
        count: subQueryObjects.length,
      };
    }

    case "create_task_plan": {
      const { tasks } = args;
      
      const taskIds: string[] = [];
      
      for (const taskSpec of tasks) {
        const id = taskManager.createTask(
          taskSpec.type,
          taskSpec.agent,
          taskSpec.inputs,
          taskSpec.dependencies || []
        );
        taskIds.push(id);
      }

      return {
        success: true,
        task_ids: taskIds,
        count: taskIds.length,
        tasks: taskManager.getAllTasks().map((t) => ({
          id: t.id,
          type: t.type,
          agent: t.agent,
          status: t.status,
        })),
      };
    }

    case "execute_task": {
      const { task_id } = args;
      const task = taskManager.getTask(task_id);

      if (!task) {
        return { success: false, error: "Task not found" };
      }

      if (!taskManager.canExecute(task_id)) {
        return {
          success: false,
          error: "Dependencies not met",
          dependencies: task.dependencies,
        };
      }

      taskManager.updateTaskStatus(task_id, "running");

      try {
        let result;

        if (task.agent === "A1") {
          const a1Task: A1.A1Task = {
            agent: "A1",
            action: task.type as "ingest_parse" | "retrieve",
            inputs: task.inputs,
          };
          result = await A1.run(a1Task);

          // Update memory based on A1 results
          if (result.status === "success") {
            if (result.citations) {
              memoryManager.setCitations(result.citations);
            }
            if (result.evidence) {
              memoryManager.addEvidence(result.evidence);
            }
          }
        } else if (task.agent === "A2") {
          const a2Task: A2.A2Task = {
            agent: "A2",
            action: "reason",
            inputs: task.inputs,
          };
          result = await A2.run(a2Task);
        }

        taskManager.updateTaskStatus(task_id, "completed", result);

        return {
          success: true,
          task_id,
          result,
        };
      } catch (error) {
        task.retries++;
        if (task.retries < task.maxRetries) {
          taskManager.updateTaskStatus(task_id, "pending");
          return {
            success: false,
            error: String(error),
            retry: true,
            retries: task.retries,
          };
        } else {
          taskManager.updateTaskStatus(task_id, "failed");
          return {
            success: false,
            error: String(error),
            retry: false,
          };
        }
      }
    }

    case "evaluate_evidence_quality": {
      const { evidence_count, min_required = 3 } = args;
      const evidence = memoryManager.getEvidence();

      const metrics: QualityMetrics = {
        risk_score: 0,
        missing_citations: 0,
        contradictions: 0,
        unmapped_claims: 0,
        should_retry: false,
      };

      // Check minimum evidence
      if (evidence_count < min_required) {
        metrics.missing_citations = min_required - evidence_count;
        metrics.risk_score += 30;
      }

      // Check source quality
      const lowQualityCount = evidence.filter(
        (e) => e.source_type === "metadata_only"
      ).length;
      if (lowQualityCount > evidence_count / 2) {
        metrics.risk_score += 20;
      }

      // Determine if retry needed
      if (metrics.risk_score > 40) {
        metrics.should_retry = true;
        metrics.retry_reason = "Insufficient or low-quality evidence";
      }

      return {
        success: true,
        metrics,
        evidence_count,
        quality_distribution: {
          pdf: evidence.filter((e) => e.source_type === "pdf").length,
          abstract: evidence.filter((e) => e.source_type === "abstract")
            .length,
          metadata: evidence.filter((e) => e.source_type === "metadata_only")
            .length,
        },
      };
    }

    case "get_memory_summary": {
      return {
        success: true,
        summary: memoryManager.getSummary(),
        memory: memoryManager.getMemory(),
      };
    }

    case "record_user_feedback": {
      const { query, feedback } = args;
      memoryManager.addFeedback(query, feedback);

      return {
        success: true,
        message: "Feedback recorded",
      };
    }

    case "finalize_response": {
      const { answer, citations, metadata = {} } = args;
      
      return {
        success: true,
        response: {
          answer,
          citations,
          metadata: {
            ...metadata,
            timestamp: new Date().toISOString(),
            evidence_count: memoryManager.getEvidence().length,
            citation_count: memoryManager.getCitations().length,
          },
        },
      };
    }

    default:
      return { success: false, error: `Unknown function: ${name}` };
  }
}

// ============================================================================
// AGENT LOOP
// ============================================================================

async function runController(
  userQuery: UserQuery,
  maxIterations: number = 20
): Promise<any> {
  const messages: OpenAI.Chat.ChatCompletionMessageParam[] = [
    {
      role: "system",
      content: `You are Agent A0, the Controller of a multi-agent research system.

Your responsibilities:
1. ENTRANCE: Normalize user input and hydrate memory
2. DECOMPOSE: Break complex queries into sub-queries
3. PLAN: Create task list with dependencies
4. DISPATCH: Execute tasks via A1 (data/evidence) and A2 (reasoning)
5. QUALITY GATE: Evaluate evidence quality and retry if needed
6. EXIT: Finalize response with citations

Available Agents:
- A1: Data & Evidence Agent (ingest PDFs, retrieve papers from arXiv)
- A2: Reasoning Agent (synthesize answers from evidence)

Workflow:
1. If user provides PDFs → create A1 ingest task
2. Decompose query into sub-queries
3. For each sub-query → create A1 retrieve task
4. After evidence gathered → evaluate quality
5. If quality OK → create A2 reason task
6. Finalize and return response

Memory Summary:
${memoryManager.getSummary()}

Execute systematically. You control the loop - agents don't self-loop.`,
    },
    {
      role: "user",
      content: `User Query: "${userQuery.text}"
${userQuery.sources ? `Sources: ${userQuery.sources.join(", ")}` : ""}
Expertise Level: ${userQuery.expertise || "intermediate"}
Output Format: ${userQuery.format || "markdown"}

Please process this query.`,
    },
  ];

  let iteration = 0;
  let finalResult: any = null;

  while (iteration < maxIterations) {
    iteration++;
    console.log(`\n${"=".repeat(60)}`);
    console.log(`[A0 ITERATION ${iteration}/${maxIterations}]`);
    console.log("=".repeat(60));

    const response = await openai.chat.completions.create({
      model: "gpt-4o",
      messages,
      tools,
      tool_choice: "auto",
      temperature: 0,
    });

    const message = response.choices[0].message;
    messages.push(message);

    // Check if done
    if (!message.tool_calls || message.tool_calls.length === 0) {
      console.log("\n[A0 COMPLETE]");
      finalResult = {
        status: "complete",
        message: message.content,
        iterations: iteration,
      };
      break;
    }

    // Execute tool calls
    for (const toolCall of message.tool_calls) {
      const functionName = toolCall.function.name;
      const functionArgs = JSON.parse(toolCall.function.arguments);

      const result = await executeFunction(functionName, functionArgs);

      // Check for finalization
      if (functionName === "finalize_response" && result.success) {
        finalResult = result.response;
      }

      messages.push({
        role: "tool",
        tool_call_id: toolCall.id,
        content: JSON.stringify(result),
      });
    }

    // Exit if finalized
    if (finalResult) {
      console.log("\n[A0 FINALIZED]");
      break;
    }
  }

  if (!finalResult) {
    finalResult = {
      status: "max_iterations",
      iterations: iteration,
      message: "Maximum iterations reached",
    };
  }

  return finalResult;
}

