export interface UserQuery {
  text: string;
  expertise?: "novice" | "intermediate" | "expert";
  format?: "markdown" | "latex" | "html";
  sources?: string[]; // PDF paths
}

export interface Memory {
  queries: string[];
  citations: A1.Citation[];
  evidence: A1.Evidence[];
  conversations: Array<{
    query: string;
    answer: string;
    timestamp: string;
  }>;
  feedback: Array<{
    query: string;
    feedback: string;
    timestamp: string;
  }>;
}

export interface SubQuery {
  id: string;
  text: string;
  priority: number;
  status: "pending" | "running" | "completed" | "failed";
}

export interface Task {
  id: string;
  type: "ingest" | "retrieve" | "reason";
  agent: "A1" | "A2";
  inputs: any;
  dependencies: string[];
  status: "pending" | "running" | "completed" | "failed";
  result?: any;
  retries: number;
  maxRetries: number;
}

export interface QualityMetrics {
  risk_score: number;
  missing_citations: number;
  contradictions: number;
  unmapped_claims: number;
  should_retry: boolean;
  retry_reason?: string;
}

// ============================================================================
// MEMORY MANAGER
// ============================================================================

class MemoryManager {
  private memory: Memory = {
    queries: [],
    citations: [],
    evidence: [],
    conversations: [],
    feedback: [],
  };

  reset() {
    this.memory = {
      queries: [],
      citations: [],
      evidence: [],
      conversations: [],
      feedback: [],
    };
  }

  addQuery(query: string) {
    if (!this.memory.queries.includes(query)) {
      this.memory.queries.push(query);
    }
  }

  setCitations(citations: A1.Citation[]) {
    this.memory.citations = citations;
  }

  getCitations(): A1.Citation[] {
    return this.memory.citations;
  }

  addEvidence(evidence: A1.Evidence[]) {
    this.memory.evidence.push(...evidence);
  }

  getEvidence(): A1.Evidence[] {
    return this.memory.evidence;
  }

  clearEvidence() {
    this.memory.evidence = [];
  }

  addConversation(query: string, answer: string) {
    this.memory.conversations.push({
      query,
      answer,
      timestamp: new Date().toISOString(),
    });
  }

  addFeedback(query: string, feedback: string) {
    this.memory.feedback.push({
      query,
      feedback,
      timestamp: new Date().toISOString(),
    });
  }

  getSummary(): string {
    return JSON.stringify({
      total_queries: this.memory.queries.length,
      total_citations: this.memory.citations.length,
      total_evidence: this.memory.evidence.length,
      recent_conversations: this.memory.conversations.slice(-3),
      recent_feedback: this.memory.feedback.slice(-3),
    });
  }

  getMemory(): Memory {
    return this.memory;
  }
}

